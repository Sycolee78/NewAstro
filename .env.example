# Instagram Basic Display API
# Get your access token from Facebook Developer Console
# https://developers.facebook.com/docs/instagram-basic-display-api
INSTAGRAM_ACCESS_TOKEN=

# Strava Profile URL
# Your Strava athlete profile page
STRAVA_PROFILE_URL=https://www.strava.com/athletes/your-athlete-id

# Agrimesh Repository URL
# GitHub URL for the Agrimesh project
AGRIMESH_REPO_URL=https://github.com/Sycolee78/agrimesh-autonomous

# Google Site Verification (optional)
# For Google Search Console
PUBLIC_GOOGLE_SITE_VERIFICATION=
