---
// src/pages/projects.astro
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE } from "@/config";

// Project data - can be moved to a separate file or CMS later
const projects: Array<{
  title: string;
  status: "In Progress" | "Completed" | "Archived";
  description: string;
  githubUrl?: string;
  tags?: string[];
}> = [
  {
    title: "AgriMesh Autonomous",
    status: "In Progress",
    description:
      "Agent-driven Farm OS for Zimbabwe. An autonomous farm intelligence system that designs and simulates smart agricultural layouts based on geospatial land selection. Integrates AI planning, environmental modeling, and agent-based positioning to optimize crop selection, livestock placement, and farm profitability.",
    githubUrl: "https://github.com/Sycolee78/agrimesh-autonomous",
    tags: ["Python", "AI/ML", "Simulation", "Agriculture", "FastAPI"],
  },
  {
    title: "Tank Failure Pressure Prediction",
    status: "Completed",
    description:
      "Machine learning project that predicts target pressure (bar) for tank failure from engineering and process features. Uses advanced ML models to analyze structural data and predict failure points for safety applications.",
    githubUrl: "https://github.com/Sycolee78/Tank-Failure-Pressure-Prediction",
    tags: ["Python", "Machine Learning", "Data Science", "Engineering"],
  },
  {
    title: "Blog Management System",
    status: "Completed",
    description:
      "Modern full-stack blog application with a portfolio-style responsive grid UI. Supports thumbnail uploads, categories, excerpts, and complete CRUD operations. Built with a RESTful API, clean architecture, and intuitive UX featuring validation, loading states, and responsive design.",
    githubUrl: "https://github.com/Sycolee78/Blog-Management",
    tags: ["Full-Stack", "REST API", "CRUD", "Responsive Design"],
  },
  {
    title: "Avail Sport Application",
    status: "In Progress",
    description:
      "A FlutterFlow app connecting users with sports, gym, and educational activities in Mauritius. Features activity discovery, booking system, and user profiles.",
    tags: ["FlutterFlow", "Firebase", "Mobile App", "Figma"],
  },
  {
    title: "Online Classroom Platform",
    status: "Completed",
    description:
      "Internal learning platform for Accenture employees, featuring live sessions, resource sharing, and progress tracking. Built with enterprise-grade architecture.",
    tags: ["Spring Boot", "Java", "React.js", "MongoDB", "REST API"],
  },
];
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Breadcrumb />

  <main id="main-content">
    <section id="projects" class="pb-6 pt-8">
      <h1 class="text-2xl font-semibold tracking-wider sm:text-3xl">
        Projects
      </h1>
      <p class="mt-4 mb-8 text-foreground/80">
        A collection of projects I'm working on — from security tools to intelligent systems.
      </p>

      <div class="grid gap-6 sm:grid-cols-1 lg:grid-cols-2">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            status={project.status}
            description={project.description}
            githubUrl={project.githubUrl}
            tags={project.tags}
          />
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
