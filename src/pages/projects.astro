---
// src/pages/projects.astro
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE } from "@/config";

// Project data - can be moved to a separate file or CMS later
const projects: Array<{
  title: string;
  status: "In Progress" | "Completed" | "Archived";
  description: string;
  githubUrl?: string;
  tags?: string[];
}> = [
  {
    title: "Agrimesh",
    status: "In Progress",
    description:
      "Agrimesh is an autonomous farm intelligence system that designs and simulates smart agricultural layouts based on geospatial land selection. The system integrates AI planning, environmental modeling, and agent-based positioning to optimize crop selection, livestock placement, and farm profitability.",
    githubUrl: import.meta.env.AGRIMESH_REPO_URL || "https://github.com/Sycolee78/agrimesh",
    tags: ["Python", "AI/ML", "Simulation", "Agriculture"],
  },
];
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Breadcrumb />

  <main id="main-content">
    <section id="projects" class="pb-6 pt-8">
      <h1 class="text-2xl font-semibold tracking-wider sm:text-3xl">
        Projects
      </h1>
      <p class="mt-4 mb-8 text-foreground/80">
        A collection of projects I'm working on — from security tools to intelligent systems.
      </p>

      <div class="grid gap-6 sm:grid-cols-1 lg:grid-cols-2">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            status={project.status}
            description={project.description}
            githubUrl={project.githubUrl}
            tags={project.tags}
          />
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
