---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Hr from "@/components/Hr.astro";
import InstagramFeed from "@/components/InstagramFeed.astro";
import StravaLink from "@/components/StravaLink.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured).slice(0, 3);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index" class="pt-24 sm:pt-32">
    <!-- Hero -->
    <section id="hero" class="pb-16">
      <p class="font-semibold text-slate-500 dark:text-slate-400 tracking-wide">
        Hi, my name is
      </p>
      <h1 class="mt-2 text-4xl sm:text-5xl md:text-6xl font-bold text-slate-900 dark:text-slate-50">
        Emmanuel Buruvuru
      </h1>
      <p class="mt-4 max-w-xl text-base sm:text-lg text-slate-700 dark:text-slate-300">
        I'm a cybersecurity-focused software engineer from Harare, Zimbabwe. I build secure,
        resilient systems and tools that people can trust.
      </p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
        {SOCIALS.length > 0 && (
          <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
            <span class="whitespace-nowrap font-medium">Find me on</span>
            <Socials />
          </div>
        )}

        <a
          href="/assets/Buruvuru-Emmanuel-Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded border border-slate-900 dark:border-slate-100 px-4 py-2 text-sm font-semibold text-slate-900 dark:text-slate-100 transition hover:bg-slate-900 hover:text-white dark:hover:bg-slate-100 dark:hover:text-slate-900"
        >
          View résumé
        </a>
      </div>
    </section>

    <Hr />

    <!-- Let's work together / What I do -->
    <section id="work" class="py-12">
      <h2 class="text-2xl sm:text-3xl font-semibold text-slate-900 dark:text-slate-50">
        Let's work together.
      </h2>
      <p class="mt-4 max-w-2xl text-slate-700 dark:text-slate-300">
        I help teams design and build secure, reliable software — from backend systems and
        internal tools to security architectures that actually hold up under pressure.
      </p>

      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <div class="rounded-lg border border-slate-200 dark:border-slate-700 p-6">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Secure systems</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Designing and implementing services with security baked in from day zero:
            authentication, authorization, policy, and observability.
          </p>
        </div>
        <div class="rounded-lg border border-slate-200 dark:border-slate-700 p-6">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Product engineering</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Building end-to-end features, APIs, and internal tools that balance performance,
            maintainability, and clear user experience.
          </p>
        </div>
        <div class="rounded-lg border border-slate-200 dark:border-slate-700 p-6">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Technical partnerships</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Working closely with founders and teams who care about long-term resilience,
            not just quick shipping.
          </p>
        </div>
      </div>
    </section>

    <Hr />

    <!-- Selected work / Writing (using featured posts as a lightweight portfolio/blog surface) -->
    {featuredPosts.length > 0 && (
      <section id="selected-work" class="py-12">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="text-2xl sm:text-3xl font-semibold text-slate-900 dark:text-slate-50">
            Selected writing & experiments
          </h2>
          <a
            href="/archives"
            class="text-sm font-medium text-blue-600 dark:text-orange-400 hover:underline"
          >
            View all
          </a>
        </div>

        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <a
              href={getPath(post.id, post.filePath)}
              class="block rounded-lg border border-slate-200 dark:border-slate-700 p-6 transition hover:border-slate-400 dark:hover:border-slate-500"
            >
              {post.data.pubDatetime && (
                <span class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">
                  {post.data.pubDatetime.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" })}
                </span>
              )}
              <h3 class="mt-2 text-lg font-semibold text-slate-900 dark:text-slate-50">{post.data.title}</h3>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{post.data.description ?? ""}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <Hr />

    <!-- Beyond the keyboard: training & life -->
    <section id="beyond" class="py-12">
      <h2 class="text-2xl sm:text-3xl font-semibold text-slate-900 dark:text-slate-50">
        Beyond the keyboard.
      </h2>
      <p class="mt-4 max-w-2xl text-slate-700 dark:text-slate-300">
        I train like an athlete and build like an engineer. Badminton, running, and writing are
        how I practice discipline, resilience, and long-term thinking.
      </p>

      <div class="mt-8 space-y-10">
        <div>
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Training</h3>
          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">
            I track my training on Strava — running and conditioning that feed directly into my
            work and life.
          </p>
          <div class="mt-4">
            <StravaLink profileUrl="https://www.strava.com/athletes/132983852" />
          </div>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Snapshots</h3>
          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">
            Small windows into what I'm up to when I'm not at the keyboard.
          </p>
          <div class="mt-4">
            <InstagramFeed limit={6} />
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
