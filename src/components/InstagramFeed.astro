---
// src/components/InstagramFeed.astro
import IconInstagram from "@/assets/icons/IconInstagram.svg";

interface InstagramPost {
  id: string;
  caption: string;
  imageUrl: string;
  permalink: string;
  timestamp: string;
}

// Fetch posts at build time (SSG) or request time (SSR)
let posts: InstagramPost[] = [];
let error: string | null = null;

try {
  const accessToken = import.meta.env.INSTAGRAM_ACCESS_TOKEN;
  
  if (accessToken) {
    const url = `https://graph.instagram.com/me/media?fields=id,caption,media_url,media_type,permalink,timestamp,thumbnail_url&access_token=${accessToken}&limit=6`;
    const response = await fetch(url);
    
    if (response.ok) {
      const data = await response.json();
      posts = data.data.map((post: any) => ({
        id: post.id,
        caption: post.caption?.slice(0, 100) || "",
        imageUrl: post.media_type === "VIDEO" ? post.thumbnail_url : post.media_url,
        permalink: post.permalink,
        timestamp: post.timestamp,
      }));
    }
  }
} catch (e) {
  error = "Could not load Instagram feed";
}

const hasContent = posts.length > 0;
---

<section class="mb-12">
  <div class="mb-6 flex items-center gap-3">
    <IconInstagram class="h-6 w-6 text-accent" />
    <h2 class="text-xl font-bold tracking-wider sm:text-2xl">
      Latest Training & Life Updates
    </h2>
  </div>

  {hasContent ? (
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
      {posts.map((post) => (
        <a
          href={post.permalink}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative aspect-square overflow-hidden rounded-lg border border-border transition-all hover:border-accent hover:shadow-lg"
          aria-label={post.caption || "View Instagram post"}
        >
          <img
            src={post.imageUrl}
            alt={post.caption || "Instagram post"}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/60 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <p class="p-3 text-xs text-white line-clamp-2">
              {post.caption || "View on Instagram"}
            </p>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="rounded-lg border border-dashed border-border p-8 text-center">
      <IconInstagram class="mx-auto mb-3 h-8 w-8 text-foreground/40" />
      <p class="text-foreground/60">
        {error || "Instagram feed coming soon!"}
      </p>
      <a
        href="https://instagram.com/emmanuel.buruvuru"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-block text-accent hover:underline"
      >
        Follow me on Instagram →
      </a>
    </div>
  )}

  <div class="mt-4 text-center">
    <a
      href="https://instagram.com/emmanuel.buruvuru"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm text-foreground/70 transition-colors hover:text-accent"
    >
      <IconInstagram class="h-4 w-4" />
      Follow @emmanuel.buruvuru
    </a>
  </div>
</section>
