---
// src/components/StravaLink.astro
// Strava profile link component

export interface Props {
  profileUrl?: string;
}

const { profileUrl = "https://www.strava.com/athletes/132983852" } = Astro.props;
---

<section id="training" class="py-8">
  <h2 class="mb-4 text-xl font-semibold tracking-wider sm:text-2xl">
    Training
  </h2>
  
  <p class="mb-6 text-foreground/80">
    I track my runs and training on Strava. Follow along to see the work behind the results.
  </p>
  
  <a
    href={profileUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-3 rounded-lg bg-[#FC4C02] px-5 py-3 font-medium text-white transition-all hover:bg-[#E34402] hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[#FC4C02] focus:ring-offset-2 focus:ring-offset-background"
    aria-label="Follow my training journey on Strava"
  >
    <!-- Strava Logo SVG -->
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/>
    </svg>
    Follow My Training Journey
  </a>
</section>
